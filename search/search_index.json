{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u7814\u7a76\u5ba4\u52c9\u5f37\u4f1a","text":"<p>\u7814\u7a76\u5ba4\u306e\u52c9\u5f37\u4f1a\u30fb\u8f2a\u8b1b\u3067\u53d6\u308a\u4e0a\u3052\u305f\u8ad6\u6587\u306e\u307e\u3068\u3081\u30b5\u30a4\u30c8\u3067\u3059\u3002 \u97f3\u58f0\u8a8d\u8b58\u30fb\u97f3\u58f0\u5408\u6210\u30fb\u6a5f\u68b0\u5b66\u7fd2\u30fb\u6df1\u5c64\u5b66\u7fd2\u30fbTransformer\u30fbLLM \u3092\u4e2d\u5fc3\u306b\u6271\u3044\u307e\u3059\u3002</p>"},{"location":"#_2","title":"\u30bb\u30c3\u30b7\u30e7\u30f3\u4e00\u89a7","text":"\u65e5\u4ed8 \u30bf\u30a4\u30c8\u30eb \u767a\u8868\u8cc7\u6599 2026-04-18 DL Ch6.1 \u56fa\u5b9a\u57fa\u5e95\u95a2\u6570\u306e\u9650\u754c \u30b9\u30e9\u30a4\u30c9"},{"location":"#_3","title":"\u4f7f\u3044\u65b9","text":"<p>\u65b0\u3057\u3044\u30bb\u30c3\u30b7\u30e7\u30f3\u3092\u8ffd\u52a0\u3059\u308b\u306b\u306f \u30c6\u30f3\u30d7\u30ec\u30fc\u30c8 \u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/","title":"6.1 \u56fa\u5b9a\u57fa\u5e95\u95a2\u6570\u306e\u9650\u754c","text":"<p>\u51fa\u5178: C. M. Bishop, H. Bishop, Deep Learning, Springer 2024, \u00a76.1 \u62c5\u5f53: \uff08\u62c5\u5f53\u8005\u540d\uff09 \u65e5\u4ed8: 2025-04-18</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/#_1","title":"\u30b9\u30e9\u30a4\u30c9","text":"<ul> <li>\u30b9\u30e9\u30a4\u30c9 (HTML)</li> <li>\u30b9\u30e9\u30a4\u30c9 (PDF)</li> </ul>"},{"location":"sessions/2026-04-18-dl-ch6-1/#_2","title":"\u6982\u8981","text":"<p>\u7dda\u5f62\u57fa\u5e95\u95a2\u6570\u30e2\u30c7\u30eb\u306f\u7406\u8ad6\u4e0a\u3042\u3089\u3086\u308b\u95a2\u6570\u3092\u8fd1\u4f3c\u3067\u304d\u308b\u3002\u3057\u304b\u3057\u57fa\u5e95\u95a2\u6570\u304c\u30c7\u30fc\u30bf\u304b\u3089\u72ec\u7acb\u3057\u3066\u56fa\u5b9a\u3055\u308c\u3066\u3044\u308b\u3068\u3044\u3046\u4eee\u5b9a\u304c\u3001\u9ad8\u6b21\u5143\u306e\u5b9f\u554f\u984c\u3067\u306f\u6df1\u523b\u306a\u9650\u754c\u3092\u3082\u305f\u3089\u3059\u3002\u672c\u7bc0\u3067\u306f\u305d\u306e\u9650\u754c\u30924\u3064\u306e\u89b3\u70b9\u3067\u6574\u7406\u3057\u3001\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u306e\u5fc5\u8981\u6027\u3092\u52d5\u6a5f\u3065\u3051\u308b\u3002</p> <p>\u7dda\u5f62\u57fa\u5e95\u95a2\u6570\u30e2\u30c7\u30eb\u306e\u5f62\u5f0f\uff1a</p> \\[y(\\mathbf{x}, \\mathbf{w}) = f\\!\\left(\\sum_{j=1}^{M} w_j \\phi_j(\\mathbf{x}) + w_0\\right)\\] <ul> <li>\\(\\phi_j(\\mathbf{x})\\)\uff1a\u56fa\u5b9a\u3055\u308c\u305f\u975e\u7dda\u5f62\u57fa\u5e95\u95a2\u6570</li> <li>\\(\\mathbf{w}\\)\uff1a\u8a13\u7df4\u30c7\u30fc\u30bf\u304b\u3089\u5b66\u7fd2\u3059\u308b\u30d1\u30e9\u30e1\u30fc\u30bf</li> </ul>"},{"location":"sessions/2026-04-18-dl-ch6-1/#611-curse-of-dimensionality","title":"6.1.1 \u6b21\u5143\u306e\u546a\u3044\uff08Curse of Dimensionality\uff09","text":"<p>\u5165\u529b\u6b21\u5143 \\(D\\) \u304c\u5897\u3048\u308b\u3068\u3001\u591a\u9805\u5f0f\u30e2\u30c7\u30eb\u306e\u4fc2\u6570\u6570\u304c \\(O(D^M)\\) \u3067\u7206\u767a\u3059\u308b\uff08\\(M\\) \u6b21\u306e\u5834\u5408\uff09\u3002</p> <p>\u30b0\u30ea\u30c3\u30c9\u5206\u5272\u306b\u3088\u308b\u5206\u985e\u306e\u5931\u6557\u4f8b\uff1a</p> <p>\u5165\u529b\u7a7a\u9593\u3092\u30b0\u30ea\u30c3\u30c9\u30bb\u30eb\u306b\u5206\u5272\u3059\u308b\u5358\u7d14\u306a\u624b\u6cd5\u3067\u306f\u3001\u30bb\u30eb\u6570\u304c\u6b21\u5143 \\(D\\) \u306b\u5bfe\u3057\u3066 \u6307\u6570\u7684 \u306b\u5897\u52a0\u3059\u308b\u3002\u5404\u30bb\u30eb\u3092\u57cb\u3081\u308b\u306e\u306b\u5fc5\u8981\u306a\u8a13\u7df4\u30c7\u30fc\u30bf\u91cf\u3082\u540c\u69d8\u306b\u6307\u6570\u7684\u306b\u5897\u3048\u308b\u3002</p> <pre><code>graph LR\n    D1[\"D=1&lt;br/&gt;2\u30bb\u30eb\"] --&gt; D2[\"D=2&lt;br/&gt;4\u30bb\u30eb\"] --&gt; D3[\"D=3&lt;br/&gt;8\u30bb\u30eb\"] --&gt; DN[\"D=N&lt;br/&gt;2^N \u30bb\u30eb\"]\n    style DN fill:#e55,color:#fff</code></pre> <p>\u56fa\u5b9a\u57fa\u5e95\u95a2\u6570\u3092\u7528\u3044\u308b\u9650\u308a\u3001\u6b21\u5143\u306e\u546a\u3044\u3092\u56de\u907f\u3059\u308b\u306b\u306f\u57fa\u5e95\u95a2\u6570\u306e\u9078\u3073\u65b9\u3092\u5de5\u592b\u3059\u308b\u3057\u304b\u306a\u3044\u3002</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/#612","title":"6.1.2 \u9ad8\u6b21\u5143\u7a7a\u9593\u306e\u6027\u8cea","text":"<p>\u4f4e\u6b21\u5143\u3067\u57f9\u3063\u305f\u76f4\u611f\u306f\u9ad8\u6b21\u5143\u3067\u306f\u901a\u7528\u3057\u306a\u3044\u3002</p> <p>\u8d85\u7403\u306e\u4f53\u7a4d\u96c6\u4e2d\uff1a</p> <p>\\(D\\) \u6b21\u5143\u8d85\u7403\uff08\u534a\u5f84 \\(r=1\\)\uff09\u306b\u304a\u3044\u3066\u3001\u8868\u9762\u4ed8\u8fd1\u306e\u8584\u3044\u6bbb \\([1-\\varepsilon, 1]\\) \u306b\u542b\u307e\u308c\u308b\u4f53\u7a4d\u306e\u5272\u5408\u306f\uff1a</p> \\[1 - (1-\\varepsilon)^D \\xrightarrow{D\\to\\infty} 1\\] <p>\u9ad8\u6b21\u5143\u3067\u306f \u4f53\u7a4d\u306e\u307b\u307c\u3059\u3079\u3066\u304c\u8868\u9762\u4ed8\u8fd1\u306b\u96c6\u4e2d \u3059\u308b\u3002\u540c\u69d8\u306b\u30ac\u30a6\u30b9\u5206\u5e03\u3067\u3082\u78ba\u7387\u8cea\u91cf\u304c\u7279\u5b9a\u534a\u5f84\u306e\u8584\u3044\u6bbb\u306b\u96c6\u4e2d\u3059\u308b\u3002</p> <p>\u793a\u5506</p> <p>\u9ad8\u6b21\u5143\u3067\u306f\u4f4e\u6b21\u5143\u306e\u76f4\u611f\u304c\u901a\u7528\u3057\u306a\u3044\u3002\u672c\u66f8\u306e\u53ef\u8996\u5316\u4f8b\uff081\u301c2\u5909\u6570\uff09\u306f\u7406\u89e3\u3092\u52a9\u3051\u308b\u304c\u3001\u9ad8\u6b21\u5143\u3078\u306e\u4e00\u822c\u5316\u306b\u306f\u6ce8\u610f\u304c\u5fc5\u8981\u3002</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/#613-data-manifolds","title":"6.1.3 \u30c7\u30fc\u30bf\u591a\u69d8\u4f53\uff08Data Manifolds\uff09","text":"<p>\u5b9f\u30c7\u30fc\u30bf\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u5168\u4f53\u306b\u5e83\u304c\u3063\u3066\u3044\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u3088\u308a\u4f4e\u6b21\u5143\u306e\u591a\u69d8\u4f53\u4e0a\u306b\u5b58\u5728\u3059\u308b\u3002</p> <p>\u624b\u66f8\u304d\u6570\u5b57\u753b\u50cf\u306e\u4f8b\uff1a</p> <ul> <li>\u5404\u753b\u50cf\u306f\u30d4\u30af\u30bb\u30eb\u6570 \\(D\\) \u6b21\u5143\u7a7a\u9593\u306e1\u70b9</li> <li>\u4f4d\u7f6e \\((x, y)\\) \u3068\u5411\u304d \\(\\theta\\) \u3068\u3044\u3046 3\u81ea\u7531\u5ea6 \u3057\u304b\u5909\u52d5\u3057\u306a\u3044</li> <li>\u2192 \u753b\u50cf\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u5185\u306e 3\u6b21\u5143\u591a\u69d8\u4f53\u4e0a \u306b\u5b58\u5728\uff08\u975e\u7dda\u5f62\uff09</li> </ul> <p>\u81ea\u7136\u753b\u50cf\u3068\u30e9\u30f3\u30c0\u30e0\u753b\u50cf\u306e\u6bd4\u8f03\uff1a</p> <p>\u30e9\u30f3\u30c0\u30e0\u306b\u5404\u30d4\u30af\u30bb\u30eb\u3092\u72ec\u7acb\u30b5\u30f3\u30d7\u30ea\u30f3\u30b0\u3057\u305f\u753b\u50cf\u306f\u3001\u81ea\u7136\u753b\u50cf\u3068\u306f\u307e\u3063\u305f\u304f\u7570\u306a\u308b\u3002\u81ea\u7136\u753b\u50cf\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u306e \u307b\u3093\u306e\u308f\u305a\u304b\u306a\u90e8\u5206 \u3057\u304b\u5360\u3081\u3066\u3044\u306a\u3044\u3002</p> <pre><code>graph TB\n    A[\"\u9ad8\u6b21\u5143\u5165\u529b\u7a7a\u9593&lt;br/&gt;\uff08\u30d4\u30af\u30bb\u30eb\u6570 D \u6b21\u5143\uff09\"] --&gt; B[\"\u4f4e\u6b21\u5143\u591a\u69d8\u4f53&lt;br/&gt;\uff08\u5b9f\u30c7\u30fc\u30bf\u304c\u5b58\u5728\u3059\u308b\u90e8\u5206\uff09\"]\n    B --&gt; C[\"\u3055\u3089\u306b\u4f4e\u6b21\u5143\u306e\u90e8\u5206\u7a7a\u9593&lt;br/&gt;\uff08\u30bf\u30b9\u30af\u306b\u95a2\u9023\u3059\u308b\u65b9\u5411\u306e\u307f\uff09\"]\n    style A fill:#dde,stroke:#99b\n    style B fill:#cec,stroke:#8b8\n    style C fill:#ffd,stroke:#bb8</code></pre> <p>\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u306f\u3053\u306e\u30c7\u30fc\u30bf\u591a\u69d8\u4f53\u306b\u9069\u5fdc\u3057\u305f\u57fa\u5e95\u95a2\u6570\u3092\u5b66\u7fd2\u3059\u308b\u4ed5\u7d44\u307f\u3068\u3057\u3066\u7406\u89e3\u3067\u304d\u308b\u3002</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/#614","title":"6.1.4 \u30c7\u30fc\u30bf\u4f9d\u5b58\u57fa\u5e95\u95a2\u6570","text":"<p>\u56fa\u5b9a\u57fa\u5e95\u95a2\u6570\u306e\u9650\u754c\u3092\u514b\u670d\u3059\u308b\u30a2\u30d7\u30ed\u30fc\u30c1\u306e\u6b74\u53f2\u7684\u5909\u9077\uff1a</p> \u624b\u6cd5 \u57fa\u5e95\u95a2\u6570\u306e\u6c7a\u3081\u65b9 \u4e3b\u306a\u554f\u984c\u70b9 \u624b\u5de5\u82b8\u7279\u5fb4\u91cf \u5c02\u9580\u77e5\u8b58 + \u8a66\u884c\u932f\u8aa4 \u30a2\u30d7\u30ea\u4f9d\u5b58\u30fb\u6c4e\u5316\u56f0\u96e3 \u52d5\u5f84\u57fa\u5e95\u95a2\u6570 (RBF) \u5404\u8a13\u7df4\u70b9\u3092\u4e2d\u5fc3\u306b\u914d\u7f6e \u5927\u898f\u6a21\u30c7\u30fc\u30bf\u3067\u975e\u52b9\u7387\u3001\u904e\u5b66\u7fd2\u3057\u3084\u3059\u3044 \u30b5\u30dd\u30fc\u30c8\u30d9\u30af\u30bf\u30fc\u30de\u30b7\u30f3 (SVM) \u8a13\u7df4\u6642\u306b\u81ea\u52d5\u9078\u629e \u78ba\u7387\u51fa\u529b\u306a\u3057\u30fb\u591a\u30af\u30e9\u30b9\u975e\u5bfe\u5fdc\u30fb\u5927\u898f\u6a21\u30c7\u30fc\u30bf\u3067\u9650\u754c \u6df1\u5c64\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af \u30c7\u30fc\u30bf\u304b\u3089\u968e\u5c64\u7684\u306b\u5b66\u7fd2 \u4e0a\u8a18\u3059\u3079\u3066\u3092\u89e3\u6c7a <p>\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u306e\u512a\u4f4d\u6027</p> <ul> <li>\u5927\u898f\u6a21\u30c7\u30fc\u30bf\u3092\u52b9\u7387\u7684\u306b\u6d3b\u7528\u3067\u304d\u308b</li> <li>\u78ba\u7387\u7684\u51fa\u529b\u3092\u81ea\u7136\u306b\u751f\u6210\u3067\u304d\u308b</li> <li>\u591a\u30af\u30e9\u30b9\u5206\u985e\u306b\u81ea\u7136\u306b\u5bfe\u5fdc\u3067\u304d\u308b</li> <li>\u6df1\u3044\u968e\u5c64\u8868\u73fe\u3092\u5b66\u7fd2\u3067\u304d\u308b\uff08\u5f8c\u306e\u7ae0\u3067\u8a73\u8ff0\uff09</li> </ul>"},{"location":"sessions/2026-04-18-dl-ch6-1/#_3","title":"\u307e\u3068\u3081","text":"\u7bc0 \u554f\u984c \u30ad\u30fc\u30e1\u30c3\u30bb\u30fc\u30b8 6.1.1 \u6b21\u5143\u306e\u546a\u3044 \u30d1\u30e9\u30e1\u30fc\u30bf\u30fb\u30c7\u30fc\u30bf\u91cf\u304c\u6b21\u5143\u306b\u5bfe\u3057\u3066\u6307\u6570\u7206\u767a 6.1.2 \u9ad8\u6b21\u5143\u306e\u76f4\u611f\u8aa4\u308a \u4f53\u7a4d\u30fb\u78ba\u7387\u8cea\u91cf\u304c\u8868\u9762\u4ed8\u8fd1\u306b\u96c6\u4e2d\u3059\u308b 6.1.3 \u30c7\u30fc\u30bf\u591a\u69d8\u4f53 \u5b9f\u30c7\u30fc\u30bf\u306f\u4f4e\u6b21\u5143\u591a\u69d8\u4f53\u4e0a\u306b\u5b58\u5728\u3059\u308b 6.1.4 \u30c7\u30fc\u30bf\u4f9d\u5b58\u57fa\u5e95\u95a2\u6570 \u56fa\u5b9a\u2192\u624b\u5de5\u82b8\u2192\u5b66\u7fd2\u30d9\u30fc\u30b9\u3078\u306e\u5fc5\u7136\u7684\u306a\u9032\u5316 <p>\u7d50\u8ad6\uff1a \u57fa\u5e95\u95a2\u6570\u306f\u30c7\u30fc\u30bf\u304b\u3089\u5b66\u7fd2\u3059\u308b\u5fc5\u8981\u304c\u3042\u308b \u2192 \u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u3078</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/#_4","title":"\u611f\u60f3\u30fb\u8b70\u8ad6","text":"<ul> <li>\u6b21\u5143\u306e\u546a\u3044\u306f\u56de\u907f\u3067\u304d\u306a\u3044\u306e\u304b\uff1f\u305d\u308c\u3068\u3082\u5b9f\u30c7\u30fc\u30bf\u306e\u69cb\u9020\uff08\u591a\u69d8\u4f53\uff09\u304c\u6551\u3063\u3066\u304f\u308c\u308b\u306e\u304b\uff1f</li> <li>SVM\u304b\u3089DNN\u3078\u306e\u79fb\u884c\u306f\u4f55\u304c\u6c7a\u5b9a\u7684\u3060\u3063\u305f\u304b\uff1f</li> <li>\u300c\u5b66\u7fd2\u3055\u308c\u305f\u57fa\u5e95\u95a2\u6570\u300d\u3068\u306f\u5177\u4f53\u7684\u306b\u3069\u3093\u306a\u5f62\u3092\u3057\u3066\u3044\u308b\u306e\u304b\uff1f\uff08\u2192 6\u7ae0\u5f8c\u534a\u3067\u6df1\u6398\u308a\uff09</li> </ul>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/","title":"6.1 \u56fa\u5b9a\u57fa\u5e95\u95a2\u6570\u306e\u9650\u754c","text":"<p>Limitations of Fixed Basis Functions</p> <p>Bishop &amp; Bishop, Deep Learning, Springer 2024</p> <p>\u767a\u8868\u8005\uff1a\uff08\u62c5\u5f53\u8005\u540d\uff09 2025-04-18</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#_1","title":"\u524d\u63d0\uff1a\u7dda\u5f62\u57fa\u5e95\u95a2\u6570\u30e2\u30c7\u30eb","text":"<p>\u5206\u985e\u30fb\u56de\u5e30\u306e\u5171\u901a\u5f62\u5f0f\uff1a</p> \\[y(\\mathbf{x}, \\mathbf{w}) = f\\!\\left(\\sum_{j=1}^{M} w_j \\phi_j(\\mathbf{x}) + w_0\\right)\\] <ul> <li>\\(\\phi_j(\\mathbf{x})\\)\uff1a\u56fa\u5b9a\u3055\u308c\u305f\u975e\u7dda\u5f62\u57fa\u5e95\u95a2\u6570</li> <li>\\(\\mathbf{w}\\)\uff1a\u8a13\u7df4\u30c7\u30fc\u30bf\u304b\u3089\u5b66\u7fd2\u3059\u308b\u30d1\u30e9\u30e1\u30fc\u30bf</li> </ul> <p>\u4e00\u898b\u3059\u308b\u3068\u4e07\u80fd\u306b\u898b\u3048\u308b \u2192 \u5341\u5206\u8c4a\u5bcc\u306a \\(\\{\\phi_j\\}\\) \u304c\u3042\u308c\u3070\u3001\u539f\u7406\u4e0a\u3069\u3093\u306a\u95a2\u6570\u3082\u8fd1\u4f3c\u3067\u304d\u308b</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#_2","title":"\u3057\u304b\u3057\u2026","text":"<p>\u57fa\u5e95\u95a2\u6570\u304c \u8a13\u7df4\u30c7\u30fc\u30bf\u304b\u3089\u72ec\u7acb\u3057\u3066\u56fa\u5b9a\u3055\u308c\u3066\u3044\u308b \u3068\u3044\u3046\u4eee\u5b9a\u304c\u554f\u984c\u3092\u751f\u3080</p> <p>\u672c\u7bc0\u30674\u3064\u306e\u89b3\u70b9\u304b\u3089\u9650\u754c\u3092\u6574\u7406\u3059\u308b\uff1a</p> <ol> <li>\u6b21\u5143\u306e\u546a\u3044 \u2014 \u30d1\u30e9\u30e1\u30fc\u30bf\u6570\u304c\u7206\u767a</li> <li>\u9ad8\u6b21\u5143\u306e\u76f4\u611f\u8aa4\u308a \u2014 \u4f4e\u6b21\u5143\u306e\u76f4\u611f\u304c\u901a\u7528\u3057\u306a\u3044</li> <li>\u30c7\u30fc\u30bf\u591a\u69d8\u4f53 \u2014 \u5b9f\u30c7\u30fc\u30bf\u306f\u4f4e\u6b21\u5143\u306b\u5b58\u5728\u3059\u308b</li> <li>\u30c7\u30fc\u30bf\u4f9d\u5b58\u57fa\u5e95\u95a2\u6570 \u2014 \u89e3\u6c7a\u7b56\u306e\u6b74\u53f2</li> </ol>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#611-curse-of-dimensionality","title":"6.1.1 \u6b21\u5143\u306e\u546a\u3044 (Curse of Dimensionality)","text":"<p>\\(D\\) \u6b21\u5143\u3067 \\(M\\) \u6b21\u591a\u9805\u5f0f\u3092\u8003\u3048\u308b\u3068\u3001\u4fc2\u6570\u6570\u306f \\(O(D^M)\\) \u3067\u5897\u5927</p> <p>\u4f8b\uff1a\u30b0\u30ea\u30c3\u30c9\u5206\u5272\u306b\u3088\u308b\u5206\u985e</p> \u6b21\u5143 \\(D\\) \u30b0\u30ea\u30c3\u30c9\u30bb\u30eb\u6570\uff08\u5404\u8ef83\u5206\u5272\uff09 1 3 2 9 3 27 10 59,049 100 \\(3^{100} \\approx 5 \\times 10^{47}\\) <p>\u2192 \u30bb\u30eb\u3092\u57cb\u3081\u308b\u306e\u306b\u5fc5\u8981\u306a\u8a13\u7df4\u30c7\u30fc\u30bf\u91cf\u3082 \u6307\u6570\u7684 \u306b\u5897\u52a0</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#611","title":"6.1.1 \u6b21\u5143\u306e\u546a\u3044 \u2014 \u554f\u984c\u306e\u672c\u8cea","text":"<p>\u30b0\u30ea\u30c3\u30c9\u5206\u5272\u306e\u5931\u6557\u306e\u539f\u56e0\uff1a</p> <ul> <li>\u57fa\u5e95\u95a2\u6570\uff08\u30b0\u30ea\u30c3\u30c9\u30bb\u30eb\uff09\u304c\u554f\u984c\u304b\u3089\u72ec\u7acb\u3057\u3066\u8a2d\u8a08\u3055\u308c\u3066\u3044\u308b</li> <li>\u9ad8\u6b21\u5143\u3067\u306f\u5fc5\u7136\u7684\u306b\u591a\u304f\u306e\u30bb\u30eb\u304c\u7a7a\u306b\u306a\u308b</li> <li>\u30c6\u30b9\u30c8\u70b9\u304c\u7a7a\u306e\u30bb\u30eb\u306b\u5165\u308b\u3068\u5206\u985e\u4e0d\u80fd</li> </ul> <p>\"The difficulties arise because the basis functions were chosen independently of the problem being solved.\"</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#612","title":"6.1.2 \u9ad8\u6b21\u5143\u7a7a\u9593\u306e\u6027\u8cea","text":"<p>\\(D\\) \u6b21\u5143\u8d85\u7403\uff08\u534a\u5f841\uff09\u306e\u8868\u9762\u4ed8\u8fd1\u306e\u8584\u3044\u6bbb \\([1-\\varepsilon, 1]\\) \u306e\u4f53\u7a4d\u5272\u5408\uff1a</p> \\[\\frac{V_D(1) - V_D(1-\\varepsilon)}{V_D(1)} = 1 - (1-\\varepsilon)^D\\] \\(\\varepsilon = 0.1\\) \\(D=1\\) \\(D=5\\) \\(D=20\\) \u5272\u5408 10% 41% 88% <p>\u9ad8\u6b21\u5143\u3067\u306f\u4f53\u7a4d\u306e\u307b\u307c\u3059\u3079\u3066\u304c\u8868\u9762\u4ed8\u8fd1\u306e\u8584\u3044\u6bbb\u306b\u96c6\u4e2d\u3059\u308b\uff01</p> <p>\u30ac\u30a6\u30b9\u5206\u5e03\u3082\u540c\u69d8\uff1a\u78ba\u7387\u8cea\u91cf\u304c\u7279\u5b9a\u534a\u5f84\u306e\u8584\u3044\u6bbb\u306b\u96c6\u4e2d</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#612_1","title":"6.1.2 \u9ad8\u6b21\u5143\u306e\u76f4\u611f\u8aa4\u308a \u2014 \u307e\u3068\u3081","text":"<p>\u672c\u66f8\u3067\u306f\u7406\u89e3\u306e\u305f\u3081\u306b1\u301c2\u5909\u6570\u306e\u53ef\u8996\u5316\u3092\u591a\u7528\u3059\u308b\u304c\u2026</p> <p>\u26a0\ufe0f \u4f4e\u6b21\u5143\u3067\u57f9\u3063\u305f\u76f4\u611f\u306f\u9ad8\u6b21\u5143\u306b\u4e00\u822c\u5316\u3067\u304d\u306a\u3044</p> <p>\u305f\u3060\u3057\u9ad8\u6b21\u5143\u304c\u6709\u5229\u306a\u5834\u5408\u3082\u3042\u308b\uff1a</p> <ul> <li>\u4f4e\u6b21\u5143\u3067\u306f\u7dda\u5f62\u5206\u96e2\u3067\u304d\u306a\u3044\u30c7\u30fc\u30bf\u304c\u9ad8\u6b21\u5143\u3067\u306f\u5206\u96e2\u53ef\u80fd\u306b\u306a\u308b\u3053\u3068\u304c\u3042\u308b</li> <li>\u6b21\u5143\u3092\u5897\u3084\u3059\u3053\u3068\u3067\u554f\u984c\u304c\u300c\u7c21\u5358\u306b\u306a\u308b\u300d\u30b1\u30fc\u30b9\u3082\u5b58\u5728</li> </ul>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#613-data-manifolds","title":"6.1.3 \u30c7\u30fc\u30bf\u591a\u69d8\u4f53 (Data Manifolds)","text":"<p>\u91cd\u8981\u306a\u89b3\u5bdf\uff1a\u5b9f\u30c7\u30fc\u30bf\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u5168\u4f53\u306b\u5747\u4e00\u306b\u5b58\u5728\u3057\u306a\u3044</p> <p>\u4f8b\uff1a\u624b\u66f8\u304d\u6570\u5b57\u306e\u753b\u50cf - \u5404\u753b\u50cf\u306f \\(D\\)\uff08\u30d4\u30af\u30bb\u30eb\u6570\uff09\u6b21\u5143\u7a7a\u9593\u306e1\u70b9 - \u5b9f\u969b\u306e\u5909\u52d5\u8981\u56e0\uff1a\u4f4d\u7f6e \\((x, y)\\) + \u5411\u304d \\(\\theta\\) \u306e 3\u81ea\u7531\u5ea6 \u306e\u307f - \u2192 \u753b\u50cf\u96c6\u5408\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u5185\u306e 3\u6b21\u5143\u975e\u7dda\u5f62\u591a\u69d8\u4f53 \u4e0a\u306b\u5b58\u5728</p> <p>\u81ea\u7136\u753b\u50cf vs \u30e9\u30f3\u30c0\u30e0\u753b\u50cf\uff1a - \u30e9\u30f3\u30c0\u30e0\u306b\u30d4\u30af\u30bb\u30eb\u3092\u30b5\u30f3\u30d7\u30ea\u30f3\u30b0\u3057\u305f\u753b\u50cf\u306f\u81ea\u7136\u753b\u50cf\u3068\u5168\u304f\u7570\u306a\u308b - \u81ea\u7136\u753b\u50cf\u306f\u9ad8\u6b21\u5143\u7a7a\u9593\u306e \u3054\u304f\u4e00\u90e8 \u3057\u304b\u5360\u3081\u306a\u3044</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#613","title":"6.1.3 \u30c7\u30fc\u30bf\u591a\u69d8\u4f53 \u2014 \u793a\u5506","text":"<p>\u3082\u3057\u57fa\u5e95\u95a2\u6570\u3092\u591a\u69d8\u4f53\u306b\u5bfe\u5fdc\u3065\u3051\u3089\u308c\u308c\u3070\u2026</p> <ul> <li>\u5fc5\u8981\u306a\u57fa\u5e95\u95a2\u6570\u6570\uff1a\u30c7\u30fc\u30bf\u7a7a\u9593\u6b21\u5143 \\(D\\) \u306b\u5bfe\u3057\u3066\u6307\u6570\u7684   \u2192 \u591a\u69d8\u4f53\u306e\u6b21\u5143 \u306b\u5bfe\u3057\u3066\u6307\u6570\u7684\uff08\u5927\u5e45\u306b\u5c0f\u3055\u3044\uff09</li> </ul> <p>\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u306f\u30c7\u30fc\u30bf\u591a\u69d8\u4f53\u306b\u9069\u5fdc\u3057\u305f\u57fa\u5e95\u95a2\u6570\u3092\u5b66\u7fd2\u3059\u308b</p> <p>\u3055\u3089\u306b\u3001\u30bf\u30b9\u30af\u306b\u95a2\u9023\u3059\u308b\u591a\u69d8\u4f53\u4e0a\u306e\u65b9\u5411\u306e\u307f\u3092\u5b66\u7fd2\u3059\u308b\u3053\u3068\u3082\u3067\u304d\u308b \uff08\u4f8b\uff1a\u4f4d\u7f6e\u306f\u7121\u8996\u3057\u3066\u5411\u304d\u3060\u3051\u3092\u4e88\u6e2c\u3059\u308b\u5834\u5408\uff09</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#614","title":"6.1.4 \u30c7\u30fc\u30bf\u4f9d\u5b58\u57fa\u5e95\u95a2\u6570 \u2014 \u6b74\u53f2","text":"\u624b\u6cd5 \u30a2\u30d7\u30ed\u30fc\u30c1 \u9650\u754c \u624b\u5de5\u82b8\u7279\u5fb4\u91cf \u5c02\u9580\u77e5\u8b58\u3067\u8a2d\u8a08 \u6c4e\u5316\u56f0\u96e3\u30fb\u4f9d\u5b58\u6027\u5927 \u52d5\u5f84\u57fa\u5e95\u95a2\u6570 (RBF) \u8a13\u7df4\u70b9\u3092\u57fa\u5e95\u4e2d\u5fc3\u306b \u5927\u898f\u6a21\u30c7\u30fc\u30bf\u3067\u975e\u52b9\u7387 SVM \u8a13\u7df4\u6642\u306b\u57fa\u5e95\u3092\u9078\u629e \u78ba\u7387\u51fa\u529b\u306a\u3057\u30fb\u591a\u30af\u30e9\u30b9\u975e\u5bfe\u5fdc \u6df1\u5c64NN \u30c7\u30fc\u30bf\u304b\u3089\u5b66\u7fd2 \u2014"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#614_1","title":"6.1.4 \u6df1\u5c64\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u304c\u89e3\u6c7a\u3057\u305f\u3053\u3068","text":"<p>SVM\u306e\u9650\u754c\uff1a - \u78ba\u7387\u7684\u51fa\u529b\u3092\u751f\u6210\u3057\u306a\u3044 - 2\u30af\u30e9\u30b9\u304c\u57fa\u672c\uff08\u591a\u30af\u30e9\u30b9\u3078\u306e\u62e1\u5f35\u304c\u81ea\u7136\u3067\u306a\u3044\uff09 - \u6709\u52b9\u306a\u57fa\u5e95\u95a2\u6570\u6570\u304c\u8a13\u7df4\u30bb\u30c3\u30c8\u30b5\u30a4\u30ba\u3068\u5171\u306b\u5897\u5927</p> <p>\u6df1\u5c64NN\u306f\u3053\u308c\u3089\u3092\u3059\u3079\u3066\u514b\u670d\uff1a - \u78ba\u7387\u7684\u51fa\u529b\u3092\u81ea\u7136\u306b\u751f\u6210 - \u591a\u30af\u30e9\u30b9\u5206\u985e\u306b\u5bfe\u5fdc - \u5927\u898f\u6a21\u30c7\u30fc\u30bf\u3092\u52b9\u7387\u7684\u306b\u6d3b\u7528 - \u968e\u5c64\u7684\u8868\u73fe\u5b66\u7fd2\uff08\u5f8c\u7ae0\u3067\u8a73\u8ff0\uff09</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#_3","title":"\u307e\u3068\u3081","text":"\u7bc0 \u554f\u984c \u30ad\u30fc\u30e1\u30c3\u30bb\u30fc\u30b8 6.1.1 \u6b21\u5143\u306e\u546a\u3044 \u6307\u6570\u7206\u767a\u3067\u30b9\u30b1\u30fc\u30eb\u3057\u306a\u3044 6.1.2 \u9ad8\u6b21\u5143\u306e\u76f4\u611f\u8aa4\u308a \u4f4e\u6b21\u5143\u306e\u76f4\u611f\u3092\u4fe1\u3058\u308b\u306a 6.1.3 \u30c7\u30fc\u30bf\u591a\u69d8\u4f53 \u5b9f\u30c7\u30fc\u30bf\u306f\u4f4e\u6b21\u5143\u591a\u69d8\u4f53\u4e0a\u306b\u5b58\u5728 6.1.4 \u30c7\u30fc\u30bf\u4f9d\u5b58\u57fa\u5e95\u95a2\u6570 \u5b66\u7fd2\u30d9\u30fc\u30b9\u3078\u306e\u5fc5\u7136\u7684\u9032\u5316 <p>\u7d50\u8ad6\uff1a \u57fa\u5e95\u95a2\u6570\u306f\u30c7\u30fc\u30bf\u304b\u3089\u5b66\u7fd2\u3059\u308b\u5fc5\u8981\u304c\u3042\u308b \u2192 \u6df1\u5c64\u30cb\u30e5\u30fc\u30e9\u30eb\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u3078</p>"},{"location":"sessions/2026-04-18-dl-ch6-1/slides/#qa","title":"Q&amp;A\u30fb\u8b70\u8ad6","text":"<ul> <li>\u6b21\u5143\u306e\u546a\u3044\u306f\u30c7\u30fc\u30bf\u591a\u69d8\u4f53\u4eee\u8aac\u3067\u5b8c\u5168\u306b\u89e3\u6d88\u3055\u308c\u308b\uff1f</li> <li>SVM\u304b\u3089DNN\u3078\u306e\u300c\u6c7a\u5b9a\u7684\u306a\u300d\u79fb\u884c\u306f\u4f55\u3060\u3063\u305f\uff1f</li> <li>\u300c\u5b66\u7fd2\u3055\u308c\u305f\u57fa\u5e95\u95a2\u6570\u300d\u3068\u306f\u5177\u4f53\u7684\u306b\u3069\u3093\u306a\u5f62\uff1f\uff08\u2192 6\u7ae0\u5f8c\u534a\uff09</li> </ul>"}]}